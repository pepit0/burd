{
  "expo": {
    "name": "Burd",
    "slug": "burd",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "burd",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5f9470"
    },
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.burd.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSMicrophoneUsageDescription": "Burd uses the microphone so you can record bird calls while photographing.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5f9470"
      },
      "package": "com.burd.app",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "Burd",
      "shortName": "Burd",
      "description": "Burd is the social birding app to log sightings, identify bird calls, explore a field guide, and connect with birders near you."
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Burd uses your location to show bird sightings near you and to tag where you spotted a bird."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Burd needs access to your photos so you can add a picture to a sighting.",
          "cameraPermission": "Burd needs access to your camera so you can take a photo of a bird."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Burd uses the camera so you can capture the birds you spot.",
          "recordAudioAndroid": true,
          "microphonePermission": "Burd uses the microphone so you can record bird calls while photographing."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Burd uses the microphone so you can record bird calls while photographing."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Burd needs access to your photos so you can save the birds you capture.",
          "savePhotosPermission": "Burd needs permission to save your captured photos.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#5f9470"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/app"
    },
    "extra": {
      "router": {
        "origin": "https://burdapp.com"
      },
      "eas": {
        "projectId": "eb44b19f-d200-4f0e-a2ed-cc484af04d3e"
      }
    },
    "owner": "tempt-technologies"
  }
}
