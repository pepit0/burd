# Set to false for real birder photo ID (requires requirements-ml.txt + model download).
# Audio stays mock until AUDIO_MODEL_PATH is set — Perch is not wired yet.
INFERENCE_MOCK=false

TOP_K=3
MIN_CONFIDENCE=0.05

# Photo validation — keep false while testing with bird photos on screens/prints.
# Set true in production to reject low-confidence IDs and re-photographed media.
IMAGE_VALIDATION_ENABLED=false
VALIDATION_MIN_BIRD_CONFIDENCE=0.12
VALIDATION_MIN_SPECIES_MARGIN=0.03
VALIDATION_MAX_RECAPTURE_SCORE=0.50

# Birder checkpoint (full registry name)
IMAGE_MODEL_WEIGHTS=rope_vit_reg4_b14_capi-inat21

# Audio model (Google Perch — Apache-2.0). Leave both empty for mock sound ID.
# Option A: local SavedModel directory (download from Kaggle Models).
# AUDIO_MODEL_PATH=C:/models/perch_v2_cpu
# AUDIO_LABELS_PATH=C:/models/perch_v2_cpu/assets/labels.csv
# Option B: TensorFlow Hub / Kaggle model URL (requires ffmpeg for m4a decode).
# AUDIO_MODEL_HUB_URL=https://www.kaggle.com/models/google/bird-vocalization-classifier/frameworks/TensorFlow2/variations/perch_v2_cpu/versions/1
AUDIO_MODEL_PATH=
AUDIO_MODEL_HUB_URL=
AUDIO_LABELS_PATH=
AUDIO_MAX_SECONDS=30
AUDIO_MAX_WINDOWS=6
AUDIO_HEARD_MIN_CONFIDENCE=0.05
AUDIO_HEARD_MAX_SPECIES=8

# Checklist injection: scan at 3%, secondary injectees at 5%, top-3 by logit, 0.35 logit margin.
AUDIO_CHECKLIST_SCAN_MIN_CONFIDENCE=0.03
AUDIO_CHECKLIST_INJECTION_MIN_CONFIDENCE=0.05
AUDIO_ACOUSTIC_NATIVE_TOP_K=3
AUDIO_ACOUSTIC_LOGIT_MARGIN=0.35
# Do not inject raptor/owl/falcon checklist species below this unless raw Perch hit.
AUDIO_RAPTOR_INJECTION_MIN_CONFIDENCE=0.08
# Prefer Blue Jay over hawk/owl/falcon when jay logit is within this margin.
AUDIO_JAY_MIMIC_LOGIT_MARGIN=1.0
# Prune injected mimic confusers below this when Jay is logit-competitive.
AUDIO_MIMIC_CONFUSER_PRUNE_MAX_CONFIDENCE=0.12
# Log raw Perch vs final preds + Blue Jay / Robin softmax per chunk (dev diagnosis).
AUDIO_DEBUG=false
