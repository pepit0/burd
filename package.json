{
  "name": "burd",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "preview:website": "npx --yes serve website -l 4321",
    "generate:website-favicons": "npm run generate:favicons --prefix website/scripts",
    "generate:app-icons": "npm run generate:app-icons --prefix website/scripts",
    "verify:app-icons": "node scripts/verify-app-icons.mjs",
    "eas-build-post-install": "node scripts/verify-app-icons.mjs",
    "build:web-app": "node scripts/sync-web-app.mjs",
    "pages:build": "node scripts/pages-build.mjs",
    "deploy:website": "npm run build:web-app && npx --yes wrangler pages deploy website --project-name=burd --branch=main --commit-dirty=true && node scripts/purge-cloudflare-cache.mjs",
    "fetch-species-images": "node scripts/fetch-species-images.mjs",
    "generate-bird-catalog": "node scripts/run-python.mjs scripts/generate-bird-catalog.py",
    "generate-photo-taxonomy": "node scripts/run-python.mjs scripts/generate-photo-taxonomy.py",
    "backfill-photo-vernaculars": "node scripts/run-python.mjs scripts/backfill-photo-vernaculars.py",
    "build:regional-priors": "node scripts/run-python.mjs scripts/build-regional-priors.py --all",
    "build:regional-priors:sample": "node scripts/run-python.mjs scripts/build-regional-priors.py --sample --all",
    "patch:regional-priors:prairies": "node scripts/run-python.mjs scripts/build-regional-priors.py --region na --merge --month-stratify --max-records 12000 --bbox 49,60,-115,-95",
    "build:ecozone-checklist": "node scripts/run-python.mjs scripts/build-ecozone-checklist.py",
    "build:ecozone-checklist:prairies": "node scripts/run-python.mjs scripts/build-ecozone-checklist.py --zones canadian_prairies --max-records 2400",
    "derive:explore-checklist-freq": "node scripts/derive-explore-checklist-freq.mjs",
    "merge:regional-priors": "node scripts/run-python.mjs scripts/merge-community-priors.py"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/lora": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.49.8",
    "base64-arraybuffer": "^1.0.2",
    "expo": "^54.0.35",
    "expo-asset": "~12.0.13",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.21.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.10",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
