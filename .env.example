EXPO_PUBLIC_SUPABASE_URL=your-project-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Bird identification backend (see server/).
# Production / Expo against Fly:
#   EXPO_PUBLIC_INFERENCE_URL=https://burd-inference.fly.dev
# Local server on a physical phone (same Wi‑Fi):
#   EXPO_PUBLIC_INFERENCE_URL=http://192.168.1.50:8000
EXPO_PUBLIC_INFERENCE_URL=https://burd-inference.fly.dev

# Live sound ID chunk logging (set true in TestFlight/EAS builds for diagnosis)
EXPO_PUBLIC_SOUND_DEBUG=false

# Reality filter for photos (AI / screen / stock detection). Off by default.
# EXPO_PUBLIC_PHOTO_AUTHENTICITY=true

# Species Ask Guide + field guide profiles (Anthropic) — Supabase secrets only:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set ANTHROPIC_MODEL=claude-sonnet-4-6
#   supabase db push   # applies species_profiles cache table (0005)
#   supabase functions deploy species-ask
#   supabase functions deploy species-profile
