/favicon.ico
  Content-Type: image/x-icon

/site.webmanifest
  Content-Type: application/manifest+json; charset=utf-8

/sitemap.xml
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Content-Type: text/plain; charset=utf-8

# Marketing site static assets (hashed filenames).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Never cache the Expo app shell — it points at hashed JS/CSS bundles.
/app/
  Cache-Control: no-cache, no-store, must-revalidate

/app/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/app/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed Expo bundles can be cached forever.
/app/_expo/static/*
  Cache-Control: public, max-age=31536000, immutable

/app/assets/*
  Cache-Control: public, max-age=31536000, immutable
